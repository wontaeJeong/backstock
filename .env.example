APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/stocklab
DATA_STORAGE_PATH=./var/data
LOG_LEVEL=INFO
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DISABLE_REACT_DEVTOOLS=0

